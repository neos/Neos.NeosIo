prototype(Neos.NeosIo.CaseStudies:Helper.ProjectVolumes) < prototype(Neos.Fusion:Component) {
    volume = ''

    renderer = Neos.Fusion:Match {
        @subject = ${props.volume}
        @default = ''
        5 = '< 100h'
        10 = '100 - 499h'
        15 = '500 - 999h'
        20 = '1000 - 3000h'
        25 = '> 3000h'
    }
}
