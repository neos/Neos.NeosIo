prototype(Neos.NeosIo:Fragment.RebrandSiteHeader) < prototype(Neos.Fusion:Component) {
    @propTypes {
        @strict = true
        flyoutVariant = ${PropTypes.oneOf(['default', 'white'])}
    }
    //@toDoFe: check & fix light version
    renderer = afx`
        <header class="sticky top-0 z-1000"
                x-data="{ scrolled: false, mobileMenuOpen: false }">
            <Neos.Presentation:Background background="blue-dark-to-blue" class="relative xl:static">
                <Neos.NeosIo:Fragment.RebrandMenu flyoutVariant={"default"}/>
            </Neos.Presentation:Background>
        </header>
    `
}
