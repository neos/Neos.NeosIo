prototype(Neos.NodeTypes:TextWithImage) >
prototype(Neos.NodeTypes:TextWithImage) < prototype(Neos.NodeTypes:Image) {
    text >
    text = Neos.Neos:Editable {
        property = 'text'
    }

    className.main = 'neos-nodetypes-textwithimage'

    renderer {
        content.@process.appendText = ${value + '<div class="neos-nodetypes-textwithimage__text mb-[var(--n-spacing--y-small)] last:mb-0">' + props.text + '</div>'}
    }
}
