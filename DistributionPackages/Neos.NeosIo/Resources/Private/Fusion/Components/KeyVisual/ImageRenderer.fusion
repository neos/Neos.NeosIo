// Renders a keyVisualImage using a picture tag
prototype(Neos.NeosIo:KeyVisual.ImageRenderer) < prototype(Neos.NeosIo:KeyVisual.AbstractRenderer) {
    keyVisualImage = null
    keyVisualAlternativeText = ''

    picture = Neos.Presentation:Component.PictureTag {
        asset = ${props.keyVisualImage}
        alt = ${props.keyVisualAlternativeText}
        imgClasses = "absolute inset-0 size-full object-cover object-center"
        sizes = ${['100vw']}
        loadEager = true
    }
}
