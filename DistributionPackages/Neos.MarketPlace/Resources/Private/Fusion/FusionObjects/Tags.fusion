prototype(Neos.MarketPlace:Tags) < prototype(Neos.Fusion:Tag) {
    @context.data = ${String.split(this.data, ', ')}
    tagName = 'ul'
    content = Neos.Fusion:Loop {
        items = ${data}
        itemName = 'keyword'
        itemRenderer = Neos.Fusion:Tag {
            tagName = 'li'
            content = ${'#' + String.toLowerCase(keyword)}
        }
    }
    attributes.data-component = 'marketPlace.Tags'
    attributes.class = 'm-0 p-0 flex gap-x-2 gap-y-0.5 flex-wrap list-none'
}
