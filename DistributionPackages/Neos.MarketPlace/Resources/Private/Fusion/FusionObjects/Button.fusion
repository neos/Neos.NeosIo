prototype(Neos.MarketPlace:Button) < prototype(Neos.Fusion:Component) {
    url = ${null}
    content = ${null}
    openInNewTab = false

    renderer = afx`
        <Neos.Presentation:Button
            href={props.url}
            openInNewTab={props.openInNewTab}
            content={props.content}
        />
    `

    @if.hasContent = ${this.content}
}
