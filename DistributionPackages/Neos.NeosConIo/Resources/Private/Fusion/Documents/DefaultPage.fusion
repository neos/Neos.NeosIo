prototype(Neos.NeosIo:Fragment.PageStyles) {
    neosConIo = Neos.Fusion:Component {
        @position = 'after main'
        renderer = afx`
            <link rel="stylesheet" href={StaticResource.uri('Neos.NeosConIo', 'Public/Styles/Main.css')} />
        `
    }
}

prototype(Neos.NeosIo:Fragment.Menu) {
    @cache.entryIdentifier.documentNode = ${Neos.Caching.entryIdentifierForNode(documentNode)}
}
